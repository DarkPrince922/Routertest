BOT_TOKEN=PUT_YOUR_TOKEN_HERE
ADMIN_IDS=123456789,987654321
MAX_CONCURRENT=6
DB_PATH=./scans.db
LOG_LEVEL=INFO
# Optional HTTP-layer proxy for nuclei + banner grabbing (nmap is not proxied):
#   SCAN_PROXY=socks5://127.0.0.1:9050
SCAN_PROXY=
# routersploit: true = only factory-default creds (fast, low lockout risk);
# false = also run bruteforce modules.
RSF_DEFAULT_ONLY=true
# true = also skip deep stages when device type is undetermined (strict);
# false = scan undetermined targets anyway (lenient, default).
SKIP_UNKNOWN=false
# Port-discovery engine: auto (masscan if installed, else nmap) | masscan | nmap.
PORT_SCANNER=auto
# masscan packets-per-second (higher = faster; too high can drop replies on
# cheap routers). 5000 is a safe-fast default; raise to 10000+ on good links.
MASSCAN_RATE=5000
# nuclei template tag filter. Empty = run ALL templates (most thorough, slower).
# Set e.g. router,iot,cve,default-login,exposure,panel,misconfig to speed it up.
NUCLEI_TAGS=
# nuclei template concurrency (-c). Higher = faster per host, more CPU/RAM.
NUCLEI_CONCURRENCY=50
# Fast nmap: skip slow OS detection (-O) and use light version probes. Device
# type still comes from ports/banners/SNMP. Set false for full -sV -O.
NMAP_FAST=true
# Optional password list file for hydra in +bruteforce creds mode (empty = use
# only the small built-in default-credential list).
HYDRA_PASS_LIST=
# Metasploit stage: broad vendor exploit coverage via msfconsole. HEAVY (slow
# startup + lots of RAM) — keep false unless you have the resources. Also
# toggleable in ⚙️ Настройки.
METASPLOIT_ENABLED=false
# Max heavy tools (nuclei/routersploit) running at once, regardless of
# MAX_CONCURRENT. Keep low (1-2) on small boxes to avoid OOM; raise on big ones.
HEAVY_TOOL_LIMIT=2
# Economy mode for weak hardware: serialize heavy tools (effective limit 1),
# nuclei -c 8, throttled masscan rates, and batch subnets scanned one at a time.
# Trades speed for far lower CPU. Toggleable live in ⚙️ Настройки.
ECONOMY=false
# cve_detect active mode. false (default) = SAFE: only fingerprint + endpoint
# presence (no payloads). true = allow non-destructive ACTIVE probes (GPON
# auth-bypass compare, single known-cred try, nuclei confirm). Toggle in ⚙️.
CVE_ACTIVE=false
# vulners stage: nmap --script vulners maps detected service versions to CVEs via
# vulners.com. Needs OUTBOUND INTERNET. true by default; set false on air-gapped
# hosts. Skipped in batch/subnet scans regardless (too chatty for the API).
VULNERS_ENABLED=true
# Subnet liveness sweep: auto (masscan if installed, else nmap) | masscan | nmap.
# masscan is faster on big ranges and also finds ICMP-blocking routers.
DISCOVERY_METHOD=auto
# masscan packets-per-second for the liveness sweep (raise for faster sweeps).
DISCOVERY_RATE=20000
